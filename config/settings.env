# == Configuration ==
# Edit these values or override with CLI flags

# Ollama model to load
# You can use any GGUF model from Hugging Face:
#   hf.co/bartowski/Llama-3.2-1B-Instruct-GGUF
#   hf.co/user/repo:Q8_0          (specify quantization tag)
MODEL_NAME=qwen3:8b

# Max concurrent requests (Kaggle T4 GPUs: 1-2 recommended)
MAX_CONCURRENT=2

# Context window (tokens)
NUM_CTX=16384

# Max tokens to generate
NUM_PREDICT=16384

# Batch size for decoding
NUM_BATCH=500

# Flash attention (True/False)
FLASH_ATTN=True

# Retry on empty stream (True = retry up to 2 times, False = return error immediately)
# WARNING: Retrying re-sends the full conversation — model regenerates from start
RETRY_ON_EMPTY=False

# Assign all GPUs (-1 = all)
NUM_GPU=-1

# Keep model loaded in RAM ("60m" = 60min, "-1" = forever)
KEEP_ALIVE=60m

# FastAPI port
PORT=8000

# Debug mode (True = verbose logging, False = minimal)
DEBUG_MODE=True

# Show request log in terminal (True = show every request, False = silent)
VERBOSE_LOG=False

# == File paths (override if needed) ==
SERVER_LOG_FILE=/tmp/gateway-server.log
TUNNEL_LOG_FILE=/tmp/cloudflared.log
URL_FILE=/tmp/kaggle-ollama-url.txt
OLLAMA_PULL_LOG=/tmp/ollama-pull.log
REQUEST_LOG_FILE=/tmp/gateway-requests.log
